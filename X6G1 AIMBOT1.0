function Frames:MakeSection(Parent)
  local section = Instance.new("Frame")
  section.Parent = Parent
  section.Name = Decrypt()
  section.BackgroundTransparency = 1
  section.Size = UDim2.new(0.9, 0, 0.3, 0)
  section.Visible = true
  local corner = Instance.new("UICorner")
  corner.Parent = section
  corner.CornerRadius = UDim.new(0, 5)
  local stroke = Instance.new("UIStroke")
  stroke.Parent = section
  stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
  stroke.Color = Color3.new(1, 0, 0)
  stroke.Thickness = 1
  local list = Instance.new("UIListLayout")
  list.Parent = section
  list.Padding = UDim.new(0, 8)
  list.FillDirection = Enum.FillDirection.Vertical
  list.SortOrder = Enum.SortOrder.LayoutOrder
  list.HorizontalAlignment = Enum.HorizontalAlignment.Left
  list.HorizontalFlex = Enum.UIFlexAlignment.None
  list.VerticalAlignment = Enum.VerticalAlignment.Top
  list.VerticalFlex = Enum.UIFlexAlignment.None
  local pad = Instance.new("UIPadding")
  pad.Parent = section
  pad.PaddingBottom = UDim.new(0, 0)
  pad.PaddingLeft = UDim.new(0, 10)
  pad.PaddingRight = UDim.new(0, 0)
  pad.PaddingTop = UDim.new(0, 10)
  list:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
    section.Size = UDim2.new(0.9, 0, 0, list.AbsoluteContentSize.Y + 15)
  end)
  return section
end

